---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Diamond — MLB stats in your browser and your terminal',
  description = 'Diamond turns the public MLB Stats API into a fast web app and a beautiful terminal app, both powered by DiamondGPT — an AI that pulls live data to answer in plain English.',
} = Astro.props;
const site = Astro.site?.href ?? 'https://diamond.xavidop.me/';
const ogImage = new URL('screenshots/web-home.png', site).href;
const gaId = import.meta.env.PUBLIC_GA_ID?.trim();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#08090d" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {gaId && (
      <Fragment>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('consent', 'default', {
            ad_storage: 'denied',
            analytics_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
          });
          gtag('js', new Date());
          // Suppress the automatic page_view; the consent banner sends a
          // consent-gated page_view only once analytics_storage is granted.
          gtag('config', gaId, { send_page_view: false });
        </script>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      </Fragment>
    )}
  </head>
  <body>
    <slot />
    <CookieConsent />
  </body>
</html>
